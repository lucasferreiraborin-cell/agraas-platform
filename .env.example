# ─────────────────────────────────────────────────────────────────
# Agraas Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL of your Supabase project (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/publishable key — safe to expose client-side (respects RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Service role key — NEVER expose client-side; bypasses RLS
# Used only in server-side routes (supabase-service.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (AI Predictions) ────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
# Used by: app/api/predict-score/route.ts

ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (Billing — optional) ───────────────────────────────────
# Found in: https://dashboard.stripe.com/apikeys

# Secret key — server-side only
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — from Stripe CLI or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Publishable key — safe to expose client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
